# =============================================================================
# Database API (dental-database-backend) — environment configuration
# Copy this file to `.env` and fill in real values. Do NOT commit the real .env.
# =============================================================================

PORT=3001

# MySQL connection
# When running via docker-compose, set DB_HOST=mysql (the service name).
# When running the API directly on the host, use DB_HOST=localhost.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mydatabase
DB_USER=root

# Provided separately through a secure channel — do not commit the real value.
DB_PASSWORD=CHANGE_ME

# Authentication — generate a strong random secret (see dental-backend example)
JWT_SECRET=CHANGE_ME
