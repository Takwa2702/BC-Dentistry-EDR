# =============================================================================
# Blockchain API (dental-backend) — environment configuration
# Copy this file to `.env` and fill in real values. Do NOT commit the real .env.
# =============================================================================

PORT=3000

# Fabric network identifiers
FABRIC_CHANNEL=mychannel
FABRIC_CHAINCODE=basic

# Connection profile is copied from the running test-network at startup
# (see docs/SETUP.md, Step 5). Path is relative to the dental-backend folder.
FABRIC_CONNECTION_PROFILE=./connection/connection-org1.json
FABRIC_WALLET_PATH=./wallet

# Authentication — generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=8h

# CORS — origin allowed to call this API (the web frontend)
CORS_ORIGIN=http://localhost:5174
