# =============================================================================
# Mobile App (Expo / React Native) — environment configuration
# Copy this file to `.env`.
#
# IMPORTANT: A physical device cannot reach "localhost" — that points to the
# phone itself. Use your development machine's LAN IP instead. Find it with:
#   ip addr show | grep "inet " | grep -v 127.0.0.1
# Both the phone and the machine must be on the same Wi-Fi network.
# =============================================================================

API_BASE_URL=http://<YOUR_LAN_IP>:3001/api
BLOCKCHAIN_API_URL=http://<YOUR_LAN_IP>:3000/api
